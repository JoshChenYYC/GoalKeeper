@page "/sessions/setup/{GoalId:guid}"
@inject SetupWorkflow Workflow
@inject NavigationManager Navigation

<PageTitle>Set up this focus session · GoalKeeper</PageTitle>
<h1>Set up this focus session</h1>
<p class="lede">Choose the boundaries for this one session. GoalKeeper will lock an exact snapshot before the camera check.</p>

@if (_form is null && _error is null)
{
    <p>Loading…</p>
}
else if (_form is null)
{
    <section class="empty-state">
        <h2>This focus session isn’t ready.</h2>
        <p>@_error</p>
        <div class="actions">
            <a class="button" href="@RulesHref">Define accountability rules</a>
            <a class="button secondary" href="@($"/?goal={GoalId:D}")">Return Home</a>
        </div>
    </section>
}
else
{
    <section class="panel">
        <h2>@_draft!.GoalTitle</h2>
        <EditForm Model="_form" OnValidSubmit="ConfirmAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <label>Focus time (minutes) <InputNumber @bind-Value="_form.TargetMinutes" /></label>
            <label>
                Planned breaks <span class="hint">optional</span>
                <span id="break-schedule-help" class="field-hint">
                    Write when the break should start, then how long it should last, separated by a colon.
                    For example, <strong>25:5</strong> means “after 25 minutes of focus, take a 5-minute break.”
                    Add each additional break on a new line.
                </span>
                <InputTextArea rows="4"
                               placeholder="@BreakSchedulePlaceholder"
                               aria-describedby="break-schedule-help"
                               @bind-Value="_form.Breaks" />
            </label>
            <label>What may GoalKeeper call out?
                <InputSelect @bind-Value="_form.ReasoningMode">
                    <option value="@ReasoningMode.ProfileOnly">Only my accountability rules</option>
                    <option value="@ReasoningMode.Exploratory">Any clearly off-track visible behavior</option>
                </InputSelect>
            </label>
            <label>How quickly should GoalKeeper step in?
                <InputSelect @bind-Value="_form.Sensitivity">
                    <option value="@Sensitivity.Strict">Sooner</option>
                    <option value="@Sensitivity.Balanced">Balanced</option>
                    <option value="@Sensitivity.Relaxed">Only with stronger evidence</option>
                </InputSelect>
            </label>
            <div class="snapshot">
                <span class="eyebrow">Accountability rules snapshot</span>
                <strong>@_draft.DeviationProfileName</strong>
                <ul>@foreach (var deviation in _draft.Deviations) { <li>@deviation.Description</li> }</ul>
            </div>
            <button type="submit">Lock session plan and continue</button>
        </EditForm>
        @if (_error is not null) { <p class="error">@_error</p> }
    </section>
}

@code {
    [Parameter] public Guid GoalId { get; set; }
    private SessionContractDraft? _draft;
    private SetupForm? _form;
    private string? _error;
    private string RulesHref =>
        $"/profile?returnTo={Uri.EscapeDataString($"/?goal={GoalId:D}&guide=true")}";

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            _draft = await Workflow.PrepareAsync(GoalId);
            _form = new()
            {
                TargetMinutes = (int)_draft.TargetFocusDuration.TotalMinutes,
                Breaks = string.Join(Environment.NewLine, _draft.ScheduledBreaks.Select(x =>
                    $"{x.ActiveFocusOffset.TotalMinutes:g}:{x.Duration.TotalMinutes:g}")),
                ReasoningMode = _draft.ReasoningMode,
                Sensitivity = _draft.Sensitivity
            };
            _error = null;
        }
        catch (Exception exception) when (
            exception is DomainRuleViolationException or KeyNotFoundException)
        {
            _draft = null;
            _form = null;
            _error = exception.Message;
        }
    }

    private async Task ConfirmAsync()
    {
        try
        {
            var breaks = ParseBreaks(_form!.Breaks);
            var draft = _draft! with
            {
                TargetFocusDuration = TimeSpan.FromMinutes(_form.TargetMinutes),
                ScheduledBreaks = breaks,
                ReasoningMode = _form.ReasoningMode,
                Sensitivity = _form.Sensitivity
            };
            var setup = await Workflow.ConfirmAsync(draft);
            Navigation.NavigateTo($"/sessions/{setup.Id}/ready");
        }
        catch (Exception exception) { _error = exception.Message; }
    }

    private static IReadOnlyList<ScheduledBreakInput> ParseBreaks(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return [];
        return text.Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(line =>
            {
                var parts = line.Split(':', StringSplitOptions.TrimEntries);
                if (parts.Length != 2 || !double.TryParse(parts[0], out var offset) || !double.TryParse(parts[1], out var duration))
                    throw new DomainRuleViolationException(
                        $"GoalKeeper couldn't read the planned break \"{line}\". " +
                        "Use start:length in minutes—for example, 25:5 starts a 5-minute break after 25 minutes of focus.");
                return new ScheduledBreakInput(TimeSpan.FromMinutes(offset), TimeSpan.FromMinutes(duration));
            }).ToArray();
    }

    private sealed class SetupForm
    {
        [System.ComponentModel.DataAnnotations.Range(1, 1440)]
        public int TargetMinutes { get; set; } = 25;
        public string? Breaks { get; set; }
        public ReasoningMode ReasoningMode { get; set; }
        public Sensitivity Sensitivity { get; set; }
    }

    private static string BreakSchedulePlaceholder =>
        $"25:5{Environment.NewLine}55:10";
}
