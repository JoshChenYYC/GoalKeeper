{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "image_quality": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "value": {
          "type": "string",
          "enum": ["adequate", "limited", "unusable"]
        },
        "limitations": {
          "type": "array",
          "items": { "type": "string", "pattern": "^.{1,160}$" },
          "maxItems": 8
        }
      },
      "required": ["value", "limitations"]
    },
    "people_count": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "status": {
              "type": "string",
              "enum": ["counted"]
            },
            "value": {
              "type": "integer",
              "minimum": 1,
              "maximum": 20
            },
            "support": {
              "type": "string",
              "enum": ["direct", "partial", "inferred"]
            },
            "limitations": {
              "type": "array",
              "items": { "type": "string", "pattern": "^.{1,160}$" },
              "maxItems": 8
            }
          },
          "required": ["status", "value", "support", "limitations"]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "status": {
              "type": "string",
              "enum": ["not_visible"]
            },
            "value": {
              "type": "integer",
              "enum": [0]
            },
            "support": {
              "type": "string",
              "enum": ["direct", "partial", "inferred"]
            },
            "limitations": {
              "type": "array",
              "items": { "type": "string", "pattern": "^.{1,160}$" },
              "maxItems": 8
            }
          },
          "required": ["status", "value", "support", "limitations"]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "status": {
              "type": "string",
              "enum": ["unknown"]
            },
            "value": {
              "type": "null"
            },
            "support": {
              "type": "string",
              "enum": ["unavailable"]
            },
            "limitations": {
              "type": "array",
              "items": { "type": "string", "pattern": "^.{1,160}$" },
              "maxItems": 8
            }
          },
          "required": ["status", "value", "support", "limitations"]
        }
      ]
    },
    "objects": {
      "type": "array",
      "items": { "type": "string", "pattern": "^.{1,80}$" },
      "maxItems": 32
    },
    "visible_cues": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "subject": {
            "type": "string",
            "enum": ["visible_person", "scene"]
          },
          "kind": {
            "type": "string",
            "enum": [
              "position",
              "orientation",
              "posture",
              "gaze",
              "hand_position",
              "object_relation",
              "motion",
              "visibility",
              "other_visible"
            ]
          },
          "state": {
            "type": "string",
            "enum": ["observed", "not_visible", "not_occurring", "unknown"]
          },
          "support": {
            "type": "string",
            "enum": ["direct", "partial", "inferred", "unavailable"]
          },
          "description": { "type": "string", "pattern": "^.{1,240}$" },
          "visual_basis": { "type": ["string", "null"], "pattern": "^.{1,320}$" },
          "limitations": {
            "type": "array",
            "items": { "type": "string", "pattern": "^.{1,160}$" },
            "maxItems": 8
          }
        },
        "required": [
          "subject",
          "kind",
          "state",
          "support",
          "description",
          "visual_basis",
          "limitations"
        ]
      }
    }
  },
  "required": [
    "schema_version",
    "image_quality",
    "people_count",
    "objects",
    "visible_cues"
  ]
}
